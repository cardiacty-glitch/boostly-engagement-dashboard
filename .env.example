# HubSpot private app token (read-only scopes: crm.objects.companies.read,
# crm.objects.contacts.read, crm.objects.deals.read, crm.objects.engagements.read,
# crm.objects.owners.read, crm.schemas.companies.read)
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Postgres connection string — use Neon, Supabase, or any hosted Postgres.
# For local development with docker compose: postgresql://dashboard:changeme@localhost:5432/engagement_dashboard
DATABASE_URL=postgresql://user:password@host:5432/engagement_dashboard

# Protects the /api/sync endpoint. Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# Only needed if running docker compose locally
POSTGRES_PASSWORD=changeme
